# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used for generating absolute URLs in metadata (Open Graph, Twitter cards)
NEXT_PUBLIC_SITE_URL=https://www.kitsunebrewingco.com

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The business email address that receives contact form submissions
CONTACT_EMAIL_TO=Tyler@KitsuneBeerCo.com

# The "From" address for outgoing emails.
# Must be a domain you have verified in Resend.
# While testing you can use: onboarding@resend.dev
CONTACT_EMAIL_FROM=contact@kitsunebrewingco.com

# ─── Google Calendar (MTG Hub) ─────────────────────────────────────────────────
# When set, the calendar page uses the real Google Calendar API instead of mock data.
# Leave empty to use mock data during local development.
# Format: the calendar ID from Google Calendar settings (e.g. abc123@group.calendar.google.com)
GOOGLE_EVENTS_CALENDAR_ID=
GOOGLE_FOODTRUCK_CALENDAR_ID=
# Service account key JSON (stringified) or path to credentials file
GOOGLE_CALENDAR_CREDENTIALS=

# ─── Occasion (Event Registration) ────────────────────────────────────────────
# Future integration: set when connecting to Occasion for player registration
OCCASION_API_KEY=
OCCASION_ORG_ID=

# ─── Shopify / Inventory ──────────────────────────────────────────────────────
# Future integration: set when connecting Shopify for singles inventory
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Password to log into the /admin portal.  Change this before going to production!
ADMIN_PASSWORD=kitsune2026

# Secret used to sign the admin session cookie (HMAC-SHA256).
# Generate a random string of 32+ chars and keep it private.
ADMIN_SECRET=change-me-to-a-random-32-char-secret
